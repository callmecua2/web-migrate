---

import Navbar from '../components/UI/Navbar.astro';
import Footer from '../components/UI/Footer.astro'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Nakamura Alam Sutera – Refleksi Keluarga & Terapi Holistik Jepang",
  description = "Refleksi Keluarga & Terapi Holistik Jepang di Alam Sutera",
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --bg: #fdfcf9;
    --surface: #ffffff;
    --surface-alt: #f6f3ee;
    --text-primary: #1e1e1e;
    --text-body: #4a4a4a;
    --text-muted: #7d7d7d;
    --accent-sage: #7b8d6f;
    --accent-sage-dark: #5f7055;
    --accent-warm: #b8a088;
    --accent-warm-light: #d9cbb8;
    --promo-badge: #d4956a;
    --promo-badge-bg: #fdf2e9;
    --border: #e8e4de;
    --border-light: #f0ede7;
    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04);
    --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.06);
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.08);
    --shadow-xl: 0 20px 60px rgba(0, 0, 0, 0.1);
    --radius-sm: 6px;
    --radius-md: 12px;
    --radius-lg: 20px;
    --radius-xl: 28px;
    --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-slow: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    font-size: 16px;
  }

  body {
    font-family: "Poppins", "Inter", "Noto Sans", sans-serif;
    background-color: var(--bg);
    color: var(--text-body);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }
</style>