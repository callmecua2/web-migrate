<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nakamura Alam Sutera – Refleksi Keluarga & Terapi Holistik Jepang</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #FDFCF9;
            --surface: #FFFFFF;
            --surface-alt: #F6F3EE;
            --text-primary: #1E1E1E;
            --text-body: #4A4A4A;
            --text-muted: #7D7D7D;
            --accent-sage: #7B8D6F;
            --accent-sage-dark: #5F7055;
            --accent-warm: #B8A088;
            --accent-warm-light: #D9CBB8;
            --promo-badge: #D4956A;
            --promo-badge-bg: #FDF2E9;
            --border: #E8E4DE;
            --border-light: #F0EDE7;
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04);
            --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.08);
            --shadow-xl: 0 20px 60px rgba(0, 0, 0, 0.1);
            --radius-sm: 6px;
            --radius-md: 12px;
            --radius-lg: 20px;
            --radius-xl: 28px;
            --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --transition-slow: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: 'Inter', 'Noto Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text-body);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            overflow-x: hidden;
        }

        /* ========== NAVIGATION ========== */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 0 2rem;
            transition: all var(--transition);
            background: transparent;
        }

        .navbar.scrolled {
            background: rgba(253, 252, 249, 0.92);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: var(--shadow-sm);
            border-bottom: 1px solid var(--border-light);
        }

        .navbar-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 72px;
            transition: height var(--transition);
        }

        .navbar.scrolled .navbar-inner {
            height: 60px;
        }

        .nav-brand {
            font-family: 'Playfair Display', serif;
            font-weight: 600;
            font-size: 1.25rem;
            color: #fff;
            letter-spacing: -0.02em;
            text-decoration: none;
            transition: color var(--transition);
            white-space: nowrap;
        }

        .navbar.scrolled .nav-brand {
            color: var(--text-primary);
        }

        .nav-brand span {
            font-weight: 400;
            font-style: italic;
            font-size: 0.85rem;
            display: block;
            letter-spacing: 0.04em;
            opacity: 0.85;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.9rem;
            font-weight: 400;
            letter-spacing: 0.01em;
            transition: color var(--transition);
            position: relative;
        }

        .navbar.scrolled .nav-links a {
            color: var(--text-body);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 1.5px;
            background: currentColor;
            transition: width var(--transition);
            opacity: 0.6;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .nav-cta {
            background: var(--accent-sage);
            color: #fff !important;
            padding: 10px 22px;
            border-radius: 50px;
            font-weight: 500 !important;
            font-size: 0.85rem !important;
            letter-spacing: 0.02em;
            transition: all var(--transition) !important;
            white-space: nowrap;
        }

        .nav-cta:hover {
            background: var(--accent-sage-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(123, 141, 111, 0.3);
        }
        .nav-cta::after {
            display: none !important;
        }

        /* Mobile menu toggle */
        .menu-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            z-index: 1001;
            background: none;
            border: none;
            padding: 8px;
        }
        .menu-toggle span {
            display: block;
            width: 24px;
            height: 2px;
            background: #fff;
            border-radius: 2px;
            transition: all var(--transition);
        }
        .navbar.scrolled .menu-toggle span {
            background: var(--text-primary);
        }
        .menu-toggle.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 5px);
        }
        .menu-toggle.active span:nth-child(2) {
            opacity: 0;
        }
        .menu-toggle.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -5px);
        }

        /* ========== HERO SECTION ========== */
        .hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: url('https://images.unsplash.com/photo-1600334089648-b0d9d3028eb2?w=1600&q=80') center/cover no-repeat;
            background-position: center 40%;
            overflow: hidden;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg,
                    rgba(30, 28, 26, 0.55) 0%,
                    rgba(30, 28, 26, 0.45) 40%,
                    rgba(30, 28, 26, 0.6) 100%);
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            max-width: 700px;
            padding: 2rem;
            animation: fadeInUp 0.9s ease-out;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .promo-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--promo-badge-bg);
            color: var(--promo-badge);
            padding: 10px 20px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.02em;
            margin-bottom: 1.5rem;
            animation: pulse-glow 2.5s ease-in-out infinite;
            border: 1px solid rgba(212, 149, 106, 0.25);
        }

        .promo-dot {
            width: 8px;
            height: 8px;
            background: var(--promo-badge);
            border-radius: 50%;
            animation: pulse-dot 1.5s ease-in-out infinite;
        }

        @keyframes pulse-dot {
            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(212, 149, 106, 0.6);
            }
            50% {
                box-shadow: 0 0 0 12px rgba(212, 149, 106, 0);
            }
        }
        @keyframes pulse-glow {
            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(212, 149, 106, 0.15);
            }
            50% {
                box-shadow: 0 0 0 18px rgba(212, 149, 106, 0);
            }
        }

        .hero-title {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            font-weight: 600;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 0.75rem;
            letter-spacing: -0.02em;
        }

        .hero-subtitle {
            font-size: 1.15rem;
            color: rgba(255, 255, 255, 0.85);
            font-weight: 300;
            margin-bottom: 1rem;
            letter-spacing: 0.03em;
        }

        .hero-promo-text {
            font-size: 1.35rem;
            color: #fff;
            font-weight: 500;
            margin-bottom: 2rem;
            letter-spacing: 0.02em;
        }
        .hero-promo-text strong {
            color: #F7D9B5;
            font-weight: 700;
        }

        .hero-cta-group {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            display: inline-block;
            background: var(--accent-sage);
            color: #fff;
            padding: 14px 32px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            letter-spacing: 0.02em;
            transition: all var(--transition);
            border: none;
            cursor: pointer;
            white-space: nowrap;
        }
        .btn-primary:hover {
            background: var(--accent-sage-dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(123, 141, 111, 0.35);
        }

        .btn-outline {
            display: inline-block;
            background: transparent;
            color: #fff;
            padding: 14px 32px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            letter-spacing: 0.02em;
            border: 1.5px solid rgba(255, 255, 255, 0.5);
            transition: all var(--transition);
            cursor: pointer;
            white-space: nowrap;
        }
        .btn-outline:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: #fff;
            transform: translateY(-2px);
        }

        .hero-scroll-indicator {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 2;
            animation: bounce-down 2s ease-in-out infinite;
            cursor: pointer;
        }
        .hero-scroll-indicator svg {
            width: 28px;
            height: 28px;
            stroke: rgba(255, 255, 255, 0.7);
        }
        @keyframes bounce-down {
            0%,
            100% {
                transform: translateX(-50%) translateY(0);
            }
            50% {
                transform: translateX(-50%) translateY(10px);
            }
        }

        /* ========== TAGLINE SECTION ========== */
        .tagline-section {
            background: var(--surface);
            padding: 5rem 2rem;
            text-align: center;
            border-bottom: 1px solid var(--border-light);
        }
        .tagline-inner {
            max-width: 650px;
            margin: 0 auto;
        }
        .tagline-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            opacity: 0.7;
        }
        .tagline-heading {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 600;
            color: var(--text-primary);
            letter-spacing: -0.01em;
            margin-bottom: 0.5rem;
        }
        .tagline-sub {
            font-size: 1rem;
            color: var(--text-muted);
            font-weight: 300;
            letter-spacing: 0.04em;
        }
        .tagline-divider {
            width: 50px;
            height: 2px;
            background: var(--accent-warm-light);
            margin: 1.5rem auto;
            border-radius: 1px;
        }

        /* ========== BEST TREATMENT SECTION ========== */
        .treatments-section {
            padding: 5rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }
        .section-label {
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--accent-sage);
            margin-bottom: 0.5rem;
            text-align: center;
        }
        .section-heading {
            font-family: 'Playfair Display', serif;
            font-size: 2.4rem;
            font-weight: 600;
            color: var(--text-primary);
            text-align: center;
            letter-spacing: -0.01em;
            margin-bottom: 0.75rem;
        }
        .section-desc {
            text-align: center;
            color: var(--text-muted);
            max-width: 550px;
            margin: 0 auto 3rem;
            font-size: 0.95rem;
            line-height: 1.6;
        }

        .treatment-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1.75rem;
        }
        .treatment-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: all var(--transition-slow);
            border: 1px solid var(--border-light);
            display: flex;
            flex-direction: column;
        }
        .treatment-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
            border-color: transparent;
        }
        .treatment-card-img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            display: block;
        }
        .treatment-card-body {
            padding: 1.5rem;
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .treatment-card-tag {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--accent-sage);
            font-weight: 600;
            margin-bottom: 0.4rem;
        }
        .treatment-card-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
            letter-spacing: -0.01em;
        }
        .treatment-card-desc {
            font-size: 0.9rem;
            color: var(--text-muted);
            line-height: 1.6;
            flex: 1;
            margin-bottom: 1.25rem;
        }
        .treatment-card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
        }
        .treatment-duration {
            font-size: 0.8rem;
            color: var(--text-muted);
            font-weight: 400;
            white-space: nowrap;
        }
        .btn-card-cta {
            display: inline-block;
            background: var(--accent-sage);
            color: #fff;
            padding: 10px 20px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.85rem;
            letter-spacing: 0.02em;
            transition: all var(--transition);
            white-space: nowrap;
            text-align: center;
            border: none;
            cursor: pointer;
        }
        .btn-card-cta:hover {
            background: var(--accent-sage-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(123, 141, 111, 0.3);
        }

        /* ========== ADVANTAGES / KEUNGGULAN SECTION ========== */
        .advantages-section {
            background: var(--surface-alt);
            padding: 5rem 2rem;
        }
        .advantages-inner {
            max-width: 1100px;
            margin: 0 auto;
        }
        .advantages-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
        }
        .advantages-text h2 {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            font-weight: 600;
            color: var(--text-primary);
            letter-spacing: -0.01em;
            margin-bottom: 1rem;
        }
        .advantages-text .section-label {
            text-align: left;
        }
        .advantages-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            margin-top: 1.5rem;
        }
        .advantages-list li {
            display: flex;
            gap: 1rem;
            align-items: flex-start;
        }
        .advantages-icon {
            flex-shrink: 0;
            width: 44px;
            height: 44px;
            background: var(--surface);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-light);
        }
        .advantages-list h4 {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0.2rem;
        }
        .advantages-list p {
            font-size: 0.85rem;
            color: var(--text-muted);
            line-height: 1.5;
        }

        .advantages-gallery {
            display: grid;
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto auto;
            gap: 0.75rem;
        }
        .gallery-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: var(--radius-md);
            transition: all var(--transition-slow);
            box-shadow: var(--shadow-md);
            cursor: pointer;
            min-height: 160px;
        }
        .gallery-img:hover {
            transform: scale(1.03);
            box-shadow: var(--shadow-xl);
        }
        .gallery-img.main-img {
            grid-column: 1 / -1;
            height: 240px;
            border-radius: var(--radius-lg);
        }

        /* ========== CONTACT & MAP SECTION ========== */
        .contact-section {
            padding: 5rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            margin-top: 3rem;
        }
        .contact-info h3 {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 1rem;
            letter-spacing: -0.01em;
        }
        .contact-detail {
            display: flex;
            gap: 0.75rem;
            align-items: flex-start;
            margin-bottom: 1rem;
            font-size: 0.9rem;
            color: var(--text-body);
        }
        .contact-detail .icon {
            flex-shrink: 0;
            font-size: 1.1rem;
            margin-top: 2px;
        }
        .contact-detail a {
            color: var(--accent-sage);
            text-decoration: none;
            font-weight: 500;
            transition: color var(--transition);
        }
        .contact-detail a:hover {
            color: var(--accent-sage-dark);
        }
        .map-container {
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border-light);
            height: 350px;
            width: 100%;
        }
        .map-container iframe {
            width: 100%;
            height: 100%;
            border: none;
        }
        .social-links {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
        }
        .social-link {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--surface-alt);
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            color: var(--text-body);
            transition: all var(--transition);
            font-size: 0.9rem;
            border: 1px solid var(--border-light);
        }
        .social-link:hover {
            background: var(--accent-sage);
            color: #fff;
            border-color: var(--accent-sage);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(123, 141, 111, 0.3);
        }

        /* ========== FOOTER ========== */
        .footer {
            background: #1E1E1C;
            color: rgba(255, 255, 255, 0.7);
            padding: 3rem 2rem 2rem;
            text-align: center;
        }
        .footer-inner {
            max-width: 1100px;
            margin: 0 auto;
        }
        .footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 0.3rem;
            letter-spacing: -0.01em;
        }
        .footer-tagline {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 1.5rem;
            letter-spacing: 0.03em;
            font-style: italic;
        }
        .footer-divider {
            width: 40px;
            height: 1px;
            background: rgba(255, 255, 255, 0.2);
            margin: 1.5rem auto;
        }
        .footer-copy {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.4);
            letter-spacing: 0.03em;
        }
        .footer-links {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 0.5rem;
        }
        .footer-links a {
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            font-size: 0.85rem;
            transition: color var(--transition);
        }
        .footer-links a:hover {
            color: #fff;
        }

        /* ========== FLOATING WHATSAPP ========== */
        .floating-wa {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 999;
            width: 56px;
            height: 56px;
            background: #25D366;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 28px rgba(37, 211, 102, 0.4);
            transition: all var(--transition);
            text-decoration: none;
            cursor: pointer;
            animation: float-up 0.6s ease-out;
        }
        .floating-wa:hover {
            transform: scale(1.08);
            box-shadow: 0 12px 36px rgba(37, 211, 102, 0.5);
        }
        .floating-wa svg {
            width: 28px;
            height: 28px;
            fill: #fff;
        }
        @keyframes float-up {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ========== SCROLL REVEAL ========== */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.7s ease-out, transform 0.7s ease-out;
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ========== RESPONSIVE ========== */
        @media (max-width: 900px) {
            .advantages-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            .advantages-gallery {
                order: -1;
            }
            .gallery-img.main-img {
                height: 200px;
            }
            .contact-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            .map-container {
                height: 280px;
            }
            .hero-title {
                font-size: 2.4rem;
            }
            .hero-subtitle {
                font-size: 1rem;
            }
            .hero-promo-text {
                font-size: 1.1rem;
            }
            .nav-links {
                position: fixed;
                top: 0;
                right: -100%;
                width: 280px;
                height: 100vh;
                background: var(--surface);
                flex-direction: column;
